NODE_ENV=development
PORT=3000

# From Supabase project settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# CORS: '*' for dev, comma-separated origins for prod
CORS_ORIGINS=*

# Global rate limit per IP per minute
RATE_LIMIT_MAX=100

# OTP rate limit per phone+IP per hour
OTP_RATE_PER_HOUR=5

# Storage bucket holding product images
PRODUCT_IMAGES_BUCKET=product-images

# Prelude (https://prelude.so) — phone OTP delivery + verification.
# Required. Create an API token in the Prelude dashboard.
PRELUDE_API_TOKEN=
# Defaults to the public Prelude API; override only for testing/staging.
PRELUDE_API_BASE=https://api.prelude.dev/v2

# Super-admin bootstrap credentials. Used ONLY by `npm run seed:admin` to
# create or update the super-admin user in Supabase Auth and stamp
# profiles.role = 'admin'. After provisioning, Supabase owns the password.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
