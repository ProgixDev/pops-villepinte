{
  "expo": {
    "name": "POP'S Villepinte",
    "slug": "pops-villepinte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pops-logo.png",
    "scheme": "pops",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.progix.popsvillepinte",
      "buildNumber": "8",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "POP'S utilise ta position pour suggérer ton adresse de livraison et te montrer la carte."
      }
    },
    "android": {
      "package": "com.progix.popsvillepinte",
      "versionCode": 8,
      "adaptiveIcon": {
        "backgroundColor": "#FFCE00",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f2b40a",
          "image": "./assets/images/pops-logo.png",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      "expo-video",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "POP'S utilise ta position pour la carte et la livraison."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "= 11.11.0"
        }
      ],
      [
        "@badatgil/expo-mapbox-navigation",
        {
          "accessToken": "pk.your_public_token_here",
          "mapboxMapsVersion": "11.11.0"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/pops-logo.png",
          "color": "#FFCE00"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78ec6494-6b77-4cca-b9ef-31882f867f5f"
      }
    },
    "owner": "mohameddev7"
  }
}
