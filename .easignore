# EAS Build only needs the React Native / Expo mobile project. Everything else
# in this monorepo (Nest API, Next.js admin, driver app, supabase migrations)
# is unrelated and bloats the upload tarball — last attempt failed with
# ENOSPC while copying pops_superadmin/.next build cache to the temp dir.

# Sibling sub-projects — not part of the mobile build
server/
pops_superadmin/
pops-villepinte-driver/

# Cruft / IDE / scratch
.git/
.expo/
.vscode/
.claude/
scripts/
cred.txt
generate_menu.py

# Native build outputs (regenerated by EAS Build via prebuild)
android/
ios/

# Standard dep / build caches (most are already in .gitignore but make
# .easignore self-sufficient so removing it never re-explodes the upload)
node_modules/
dist/
build/
.next/
coverage/
*.tsbuildinfo
*.log

# Local env / secrets (EAS pulls env from project settings, not the tarball)
.env
.env.local
.env.*.local
